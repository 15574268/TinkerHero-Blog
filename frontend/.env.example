# API 地址（浏览器访问用；Docker 下填后端对外地址如 http://localhost:8080/api/v1）
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# 服务端请求后端的地址（仅 Node/SSR 用；Docker 内前端容器访问后端请填 http://backend:8080/api/v1，与 docker-compose 服务名一致）
# API_URL=http://backend:8080/api/v1

# 站点 URL（用于 SEO 和分享）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
