# ========== 数据库 ==========
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=blog

# ========== Redis ==========
REDIS_ADDR=localhost:6379

# ========== Elasticsearch（可选，搜索用） ==========
ES_URL=http://localhost:9200
ES_USER=
ES_PASSWORD=

# ========== JWT（生产环境必须修改！） ==========
JWT_SECRET=your-super-secret-key-change-in-production

# ========== OAuth（可选，后台第三方登录） ==========
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ========== 邮件 SMTP（可选，评论通知等） ==========
# 原「系统设置 - 邮件配置」改为环境变量，此处生效
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@blog.com

# ========== 上传（后台可配，此处为兜底） ==========
# 单文件最大体积（MB），默认 50
UPLOAD_MAX_FILE_SIZE_MB=50
# 允许的扩展名（逗号分隔，如 .jpg,.png,.mp4），空则用默认
# UPLOAD_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.mp4,.webm,.ogv
# CDN（后台可配 upload_cdn_enabled / upload_cdn_url，此处为兜底）
# CDN_ENABLED=false
# CDN_BASE_URL=https://cdn.example.com

# ========== 限流与登录安全（原「系统设置 - 安全设置」改为环境变量） ==========
# 全局限流：每分钟每 IP 允许的请求数，默认 100
API_RATE_LIMIT_PER_MIN=100
# 认证相关接口限流：每分钟每 IP 请求数，release 模式默认 5
AUTH_RATE_LIMIT_PER_MIN=5
# 登录失败最大次数，超过后锁定，默认 5
LOGIN_MAX_ATTEMPTS=5
# 登录锁定时长（分钟），默认 15
LOGIN_LOCKOUT_MINUTES=15

# ========== 水印（可选，原「上传与媒体」中水印相关） ==========
WATERMARK_ENABLED=false
WATERMARK_TEXT=折腾侠
WATERMARK_POSITION=bottom-right

# ========== 前端与 CORS ==========
FRONTEND_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3200

# ========== 服务 ==========
PORT=8080
GIN_MODE=debug
